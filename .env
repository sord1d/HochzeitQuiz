# ── Domain & SSL ──────────────────────────────────────────────────────────────
# Deine Domain (A-Record muss auf diesen Server zeigen)
DOMAIN=hochzeit.beispiel.de

# E-Mail für Let's Encrypt (Ablaufbenachrichtigungen)
LETSENCRYPT_EMAIL=deine@email.de

# ── Backend-URL (wird ins Frontend eingebaut) ─────────────────────────────────
# Muss identisch mit DOMAIN sein – Caddy leitet /socket.io weiter
VITE_BACKEND_URL=https://hochzeit.beispiel.de
FRONTEND_INTERNAL_PORT=8088
